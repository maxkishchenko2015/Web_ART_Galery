Options -MultiViews

# MIME types for WebAssembly and JavaScript
AddType application/wasm .wasm
AddType application/javascript .js
AddType application/json .json

# Compression. Without this the ~3.8 MB main.dart.js and multi-MB
# canvaskit.wasm ship uncompressed — the single biggest first-load cost on
# mobile. Brotli (preferred, ~30% smaller than gzip on wasm/js) with a gzip
# fallback for clients that don't advertise `br`. Both compress on the fly;
# responses stay individually cacheable via the immutable headers below.
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS application/wasm application/javascript text/javascript application/json text/html text/css image/svg+xml application/xml
</IfModule>
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/wasm application/javascript text/javascript application/json text/html text/css image/svg+xml application/xml
</IfModule>

# CORS for cross-origin checks
<IfModule mod_headers.c>
  Header set Access-Control-Allow-Origin "*"

  # Aggressive cache for hashed Flutter assets (1 year)
  <FilesMatch "\.(wasm|js|otf|ttf|png|jpg|jpeg|gif|svg|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Never cache the entry HTML so users get the new build immediately
  <FilesMatch "(index\.html|flutter_bootstrap\.js|flutter_service_worker\.js)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# SPA routing: only rewrite non-existent paths AND not for asset extensions
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.(wasm|js|json|otf|ttf|png|jpg|jpeg|gif|svg|woff2?|map)$
RewriteRule ^ index.html [QSA,L]
