{
  "permissions": {
    "allow": [
      "Bash(flutter --version)",
      "Bash(flutter pub *)",
      "Bash(flutter analyze *)",
      "Bash(flutter build *)",
      "Bash(curl -s \"https://pub.dev/api/packages/lottie\")",
      "Bash(python3 -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\(d['latest']['version']\\)\")"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash .agents/setup --quiet" }
        ]
      }
    ]
  }
}
