#!/usr/bin/env bash
#
# .agents/setup — vendor-agnostic agent config generator.
#
# Single source of truth lives in .agents/. This script mirrors it into each
# vendor's own folder (.claude, .cursor, ...) as plain COPIES (not symlinks),
# so a universal config can be rendered into each vendor's specific format.
#
# Vendor folders are generated + git-ignored + READ-ONLY. To change agent
# config, edit files under .agents/ and re-run this script. A SessionStart
# hook re-runs it automatically, so edits propagate into every new session.
#
# Usage: bash .agents/setup [--quiet]

set -euo pipefail

QUIET=0
[ "${1:-}" = "--quiet" ] && QUIET=1

# Repo root = parent of this script's directory.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SRC="$ROOT/.agents"

log() { [ "$QUIET" -eq 1 ] || printf '%s\n' "$*"; }

# mirror SRC_DIR -> DST_DIR as an exact copy (delete extras).
mirror() {
  local src="$1" dst="$2"
  rm -rf "$dst"
  mkdir -p "$dst"
  if command -v rsync >/dev/null 2>&1; then
    rsync -a --delete "$src/" "$dst/"
  else
    cp -R "$src/." "$dst/"
  fi
}

GENERATED_BANNER="# GENERATED by .agents/setup — DO NOT EDIT. Edit .agents/ and re-run .agents/setup."

# ---------------------------------------------------------------------------
# Claude Code  -> /CLAUDE.md (shim), .claude/skills, .claude/settings.json
# ---------------------------------------------------------------------------
gen_claude() {
  # CLAUDE.md is just a shim: Claude only auto-loads CLAUDE.md, so point it at
  # the agnostic AGENTS.md. All real content lives in AGENTS.md.
  {
    printf '%s\n\n' "$GENERATED_BANNER"
    printf '@AGENTS.md\n'
  } > "$ROOT/CLAUDE.md"

  # Skills become first-class invocable Claude skills under .claude/skills.
  if [ -d "$SRC/skills" ]; then
    mirror "$SRC/skills" "$ROOT/.claude/skills"
  fi

  # Settings (permissions + SessionStart hook) from the agnostic source.
  if [ -f "$SRC/vendors/claude/settings.json" ]; then
    mkdir -p "$ROOT/.claude"
    cp "$SRC/vendors/claude/settings.json" "$ROOT/.claude/settings.json"
  fi
  log "  claude  -> CLAUDE.md, .claude/skills, .claude/settings.json"
}

# ---------------------------------------------------------------------------
# Cursor  -> .cursor/rules/agents.mdc (always-applied rule -> AGENTS.md)
# ---------------------------------------------------------------------------
gen_cursor() {
  mkdir -p "$ROOT/.cursor/rules"
  {
    printf -- '---\n'
    printf 'description: Project agent context\n'
    printf 'alwaysApply: true\n'
    printf -- '---\n\n'
    printf '%s\n\n' "$GENERATED_BANNER"
    printf 'Read and follow @AGENTS.md and the skills under .agents/skills/.\n'
  } > "$ROOT/.cursor/rules/agents.mdc"
  log "  cursor  -> .cursor/rules/agents.mdc"
}

# ---------------------------------------------------------------------------
# Codex reads the root AGENTS.md natively — nothing to generate.
# ---------------------------------------------------------------------------
gen_codex() {
  log "  codex   -> reads ./AGENTS.md natively (no generation needed)"
}

log "Mirroring .agents/ -> vendor folders ..."
gen_claude
gen_cursor
gen_codex
log "Done."
